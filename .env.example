# URL base del backend (FastAPI)
VITE_API_BASE_URL=http://localhost:8000

# Supabase — obtener desde: https://supabase.com/dashboard → Project Settings → API Keys
# Usar la "Publishable key" (sb_publishable_...) — reemplaza la legacy anon key.
# La anon key (JWT) sigue funcionando pero ya no es recomendada para proyectos nuevos.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_<valor>
